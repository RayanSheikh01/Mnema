# Copy to .env and fill in. .env is git-ignored; never commit real keys.
# Loaded automatically at startup (config.load_dotenv). Exported env vars win over this file.

OPENAI_API_KEY=sk-your-key-here

# Optional overrides (defaults shown):
# MNEMA_EMBEDDING_PROVIDER=openai
# MNEMA_EMBEDDING_MODEL=text-embedding-3-small
# MNEMA_VAULT_ROOT=./vault
# MNEMA_SQLITE_PATH=./mnema.db
# MNEMA_DEFAULT_NAMESPACE=default/project/dev

# --- Local embeddings (no API key, contents never leave the machine) ---
# Install the extra first:  pip install -e .[local]
# MNEMA_EMBEDDING_PROVIDER=local
# MNEMA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# MNEMA_LOCAL_MODEL_CACHE=./models      # where the model is cached (never inside the vault)
# MNEMA_LOCAL_FILES_ONLY=false          # true = fail if the model isn't already cached (fully offline)
# MNEMA_LOCAL_DEVICE=                    # blank = auto (CPU); e.g. cpu / cuda
# MNEMA_LOCAL_BATCH_SIZE=32
# After switching a populated namespace's model, migrate it:
#   mnema-memory --reembed --namespace <namespace>
#   mnema-memory --embedding-status   # inspect configured vs stored identity
